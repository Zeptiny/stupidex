Screen {
    layout: vertical;
}

#header {
    dock: top;
    height: 3;
    padding: 1;
}

#output {
    height: 1fr;
    padding: 1;
    overflow-y: auto;
}

Input {
}

#footer {
    dock: bottom;
    height: 1;
    margin-left: 1;
    margin-right: 1;
}

#spinner {
    width: 3;
    display: none;
    margin-right: 1;
}

#model {
    color: gray;
    width: 16;
}

#status {
    color: gray;
    width: 1fr;
    text-align: right;
    margin-right: 2;
}